MR_REVIEWER_GITLAB_BASE_URL=https://gitlab.example.com
MR_REVIEWER_GITLAB_API_BASE_URL=https://api.example.com/api/api/v4
MR_REVIEWER_GITLAB_TOKEN=

MR_REVIEWER_IM_POLL_COMMAND=welink-cli im query-history-message --query-count 20
MR_REVIEWER_IM_REPLY_COMMAND=welink-cli im send-to-group
MR_REVIEWER_WELINK_GROUP_ID=group-example
MR_REVIEWER_WELINK_ONEBOX_SPACE_ID=space-example
MR_REVIEWER_WELINK_ONEBOX_PARENT_ID=parent-example
MR_REVIEWER_BOT_MENTION=@Bot
MR_REVIEWER_BOT_ACCOUNT=

MR_REVIEWER_ALLOWED_GROUPS=
MR_REVIEWER_ALLOWED_USERS=
MR_REVIEWER_ALLOWED_REPOS=

MR_REVIEWER_WORK_DIR=
MR_REVIEWER_STATE_PATH=.mr-reviewer-state.json
MR_REVIEWER_AGENT_TYPE=opencode
MR_REVIEWER_AGENT_COMMAND=opencode
# webhook inline discussion 和 IM ReviewSet 评论展示的模型名；为空时仍生成报告，但不发布 GitLab 评论。
MR_REVIEWER_AGENT_MODEL_NAME=
# IM ReviewSet 评论开关，独立于 webhook；生产首次验证建议先设为 false。
MR_REVIEWER_REVIEW_SET_POST_COMMENT=true
# webhook 与 ReviewSet 共用的发布门槛；可选 severity：suggestion/minor/major/fatal。
MR_REVIEWER_PUBLISH_MIN_SEVERITY=minor
# 可选 confidence：LOW/MEDIUM/HIGH。
MR_REVIEWER_PUBLISH_MIN_CONFIDENCE=HIGH
# OFF：不写项目调用日志；INFO：只记录调用元数据；DEBUG：另存脱敏后的完整本地诊断内容。
MR_REVIEWER_LOG_LEVEL=OFF
MR_REVIEWER_DEBUG_DIR=log/debug
# 以下旧变量仅用于兼容：未设置 MR_REVIEWER_LOG_LEVEL 时，true 等价于 DEBUG。
MR_REVIEWER_AGENT_DEBUG=false
MR_REVIEWER_AGENT_DIAGNOSTIC_DIR=
MR_REVIEWER_COMMENT_SKILL=

# 本机自测可用 127.0.0.1；GitLab 从其他机器回调本机 IP 时，改为 0.0.0.0 或实际网卡 IP。
MR_REVIEWER_WEBHOOK_HOST=127.0.0.1
MR_REVIEWER_WEBHOOK_PORT=8080
# GitLab webhook URL 需要和这里完全一致，不要额外追加尾部 /。
MR_REVIEWER_WEBHOOK_PATH=/webhook/gitlab
MR_REVIEWER_WEBHOOK_SECRET=
MR_REVIEWER_WEBHOOK_SECRET_HEADER=X-Gitlab-Token
MR_REVIEWER_WEBHOOK_POST_COMMENT=true
MR_REVIEWER_REPORT_DIR=log/webhook-reports

MR_REVIEWER_MAX_FILES=50
MR_REVIEWER_MAX_DIFF_LINES=2000
MR_REVIEWER_TASK_TIMEOUT_SECONDS=900
MR_REVIEWER_POLL_INTERVAL_SECONDS=15
